{
  "name": "tsplineforge",
  "version": "0.1.0",
  "private": true,
  "description": "Next-generation AI-powered Mesh-to-T-Spline CAD platform",
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build --filter @tsplineforge/web",
    "build:all": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "clean": "turbo run clean && rm -rf node_modules",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "k8s:deploy": "kubectl apply -k infrastructure/k8s/overlays/dev",
    "k8s:delete": "kubectl delete -k infrastructure/k8s/overlays/dev"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "eslint": "^9.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.2.5",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "overrides": {
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "overrides": {
      "typescript": "^5.4.5"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "eslint"
      ]
    }
  }
}

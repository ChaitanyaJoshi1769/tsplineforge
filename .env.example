# API Gateway
GATEWAY_PORT=3000
GATEWAY_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://tspline:password@localhost:5432/tsplineforge
DATABASE_SSL=false
REDIS_URL=redis://localhost:6379

# S3 / Object Storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=tsplineforge-models
S3_REGION=us-east-1

# NATS
NATS_URL=nats://localhost:4222

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=24h
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# Claude AI Integration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-opus-4-1
CLAUDE_MAX_TOKENS=4096

# GPU
CUDA_VISIBLE_DEVICES=0
VULKAN_DEVICE=0

# Services
GEOMETRY_ENGINE_URL=http://localhost:50051
REMESH_ENGINE_URL=http://localhost:50052
TSPLINE_KERNEL_URL=http://localhost:50053
SURFACE_FITTING_URL=http://localhost:50054
AI_TOPOLOGY_URL=http://localhost:5001

# Telemetry
JAEGER_ENDPOINT=http://localhost:6831
PROMETHEUS_ENDPOINT=http://localhost:9090
ENABLE_PROFILING=false

# Feature flags
ENABLE_COLLABORATION=true
ENABLE_AI_ASSISTANCE=true
ENABLE_GPU_ACCELERATION=true
MAX_UPLOAD_SIZE_MB=500

{
  "name": "@tsplineforge/gateway",
  "version": "0.1.0",
  "description": "TSplineForge API Gateway - Request routing, auth, orchestration",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development nodemon --exec node --loader tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "cors": "^2.8.5",
    "@types/cors": "^2.8.17",
    "dotenv": "^16.4.5",
    "jsonwebtoken": "^9.0.3",
    "bcryptjs": "^2.4.3",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "body-parser": "^1.20.2",
    "ws": "^8.15.0",
    "@types/ws": "^8.5.10",
    "redis": "^4.6.13",
    "ioredis": "^5.3.2",
    "@types/node": "^20.10.6",
    "uuid": "^9.0.1",
    "axios": "^1.6.5",
    "@grpc/grpc-js": "^1.10.0",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "@anthropic-ai/sdk": "^0.20.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.0",
    "nodemon": "^3.1.0",
    "vitest": "^1.1.3",
    "@vitest/ui": "^1.1.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
